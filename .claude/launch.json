{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "python-http",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    },
    {
      "name": "npx-serve",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-p", "3000", "."],
      "port": 3000
    },
    {
      "name": "npx-http-server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "-p", "8080", "."],
      "port": 8080
    }
  ]
}
